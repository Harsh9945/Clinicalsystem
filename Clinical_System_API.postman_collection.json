{
  "info": {
    "name": "Clinical System API",
    "description": "Complete API collection for Clinical Appointment System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"SecurePass123\",\n  \"fullName\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/patient",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", "patient"]
            }
          }
        },
        {
          "name": "Register Doctor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@example.com\",\n  \"password\": \"SecurePass123\",\n  \"fullName\": \"Dr. Sarah Smith\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/doctor?specialty=Cardiology",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", "doctor"],
              "query": [
                {
                  "key": "specialty",
                  "value": "Cardiology"
                }
              ]
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"SecurePass123\",\n  \"fullName\": \"Admin User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/Admin",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", "Admin"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "Get All Verified Doctors",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/doctors/verified",
              "host": ["{{base_url}}"],
              "path": ["doctors", "verified"]
            }
          }
        },
        {
          "name": "Verify Doctor (Admin Only)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/verify-doctor/1",
              "host": ["{{base_url}}"],
              "path": ["admin", "verify-doctor", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Book Appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorid\": 1,\n  \"patientid\": 5,\n  \"appointmentTime\": \"2026-05-15T14:30:00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/appointments/book",
              "host": ["{{base_url}}"],
              "path": ["appointments", "book"]
            }
          }
        }
      ]
    },
    {
      "name": "Consultations",
      "item": [
        {
          "name": "Get All Consultations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/consultations/all",
              "host": ["{{base_url}}"],
              "path": ["v1", "consultations", "all"]
            }
          }
        },
        {
          "name": "Get Consultation by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/consultations/1",
              "host": ["{{base_url}}"],
              "path": ["v1", "consultations", "1"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
